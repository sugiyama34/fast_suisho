# 大きなデータファイル置き場 (開始局面集など)。取得は match/fetch_books.sh 参照
/data/

# NNUE network binaries (large)。tools/ 配下のテスト用 fixture は対象外
networks/**/*.bin
experiments/**/*.bin

# built engine binaries (バイナリ専用ディレクトリ。設定類は match/ に置く)
/engines/
YaneuraOu-by-gcc*
*.o
*.exe

# python
__pycache__/
*.pyc
.venv/

# generated game records (対局で生成されるもの。互角局面集など curated な入力は games/ の外に置く)
experiments/**/games/
